# Local SQLite development
SECRET_KEY=dev-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DB_ENGINE=sqlite
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# PostgreSQL example for Docker/production
# DB_ENGINE=postgresql
# DB_NAME=site_engineer_management
# DB_USER=site_engineer
# DB_PASSWORD=site_engineer_password
# DB_HOST=db
# DB_PORT=5432
# DATABASE_URL=postgresql://site_engineer:site_engineer_password@db:5432/site_engineer_management

# Existing Docker/PostgreSQL variables remain supported
# DJANGO_SECRET_KEY=replace-this-with-a-secure-secret
# DJANGO_DEBUG=true
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
# POSTGRES_DB=site_engineer_management
# POSTGRES_USER=site_engineer
# POSTGRES_PASSWORD=site_engineer_password
# POSTGRES_HOST=db
# POSTGRES_PORT=5432

JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
ATTACHMENT_MAX_FILE_SIZE_MB=10

VITE_API_BASE_URL=http://127.0.0.1:8000/api
